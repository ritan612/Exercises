import { LightningElement, api, wire } from 'lwc';
import { NavigationMixin } from 'lightning/navigation';
import { ShowToastEvent } from 'lightning/platformShowToastEvent';
import createClosedWonOpp from '@salesforce/apex/ClosedWonOpportunityController.createClosedWonOpp';

export default class MyComponent extends NavigationMixin(LightningElement) {
    @api recordId; // Automatically gets the Account Id if placed on an Account record page
    
    // Hardcoded or dynamically fetched list of product IDs to pass
    productIds = ['01tXXXXXXXXXXXXXXX']; 

    isLoading = false;
    showSuccessModal = false;
    createdOppId = '';

    handleCreateOpportunity() {
        this.isLoading = true;

        createClosedWonOpp({ 
            accountId: this.recordId, 
            productIds: this.productIds 
        })
        .then((result) => {
            this.isLoading = false;
            // The apex wrapper returns { recordId: '...', isSuccess: true }
            if (result && result.isSuccess) {
                this.createdOppId = result.recordId;
                this.showSuccessModal = true; // Open the custom popup modal
                
                this.showToast('Success', 'Opportunity created successfully!', 'success');
            } else {
                this.showToast('Error', 'Something went wrong.', 'error');
            }
        })
        .catch((error) => {
            this.isLoading = false;
            this.showToast('Error', error.body.message, 'error');
        });
    }

    // Navigates to the newly created Opportunity
    navigateToOpportunity() {
        this.closeModal();
        this[NavigationMixin.Navigate]({
            type: 'standard__recordPage',
            attributes: {
                recordId: this.createdOppId,
                actionName: 'view'
            }
        });
    }

    closeModal() {
        this.showSuccessModal = false;
    }

    showToast(title, message, variant) {
        this.dispatchEvent(
            new ShowToastEvent({ title, message, variant })
        );
    }
}














<template>
    <lightning-card title="Opportunity Generator" icon-name="standard:opportunity">
        <div class="slds-m-around_medium">
            <template if:true={isLoading}>
                <lightning-spinner alt-text="Creating Opportunity..." size="medium"></lightning-spinner>
            </template>

            <lightning-button 
                label="Create Closed Won Opp" 
                variant="brand" 
                onclick={handleCreateOpportunity}
                disabled={isLoading}>
            </lightning-button>
        </div>
    </lightning-card>

    <template if:true={showSuccessModal}>
        <section role="dialog" tabindex="-1" aria-modal="true" class="slds-modal slds-fade-in-open">
            <div class="slds-modal__container">
                <header class="slds-modal__header">
                    <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close" onclick={closeModal}>
                        <lightning-icon icon-name="utility:close" alternative-text="close" size="small" variant="inverse"></lightning-icon>
                    </button>
                    <h2 class="slds-text-heading_medium slds-hyphenate">Success!</h2>
                </header>

                <div class="slds-modal__content slds-p-around_medium">
                    <p class="slds-text-align_center">The Closed Won Opportunity has been created successfully.</p>
                </div>

                <footer class="slds-modal__footer">
                    <button class="slds-button slds-button_neutral" onclick={closeModal}>Close</button>
                    <button class="slds-button slds-button_brand" onclick={navigateToOpportunity}>View Opportunity</button>
                </footer>
            </div>
        </section>
        <div class="slds-backdrop slds-backdrop_open"></div>
    </template>
</template>