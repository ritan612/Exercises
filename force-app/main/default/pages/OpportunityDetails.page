<apex:page standardController="Opportunity" showHeader="false" renderAs="PDF" standardStylesheets="false">
    <apex:stylesheet value="{!$Resource.Opportunity_PDF}"/>
    <body>
        <h1>Opportunity Details</h1>
        <table>
            <thead>
                <th>Name</th>
                <th>Account Name</th>
                <th>Closed Date</th>
            </thead>
            <tbody>
                <apex:variable var="opp" value="{!Opportunity}"/>
                <tr>
                    <td>{!opp.Name}</td>
                    <td>{!opp.Account.Name}</td>
                    <td>{!opp.CloseDate}</td>
                </tr>
            </tbody>
        </table>
        
        <h1>Products Details</h1>
        <table>
            <thead>
                <th>Name</th>
                <th>Quantity</th>
                <th>Price</th>
                <th>Total Price</th>
            </thead>
            <tbody>
                <apex:repeat value="{!Opportunity.OpportunityLineItems}" var="lineItem">
                    <tr>
                        <td>{!lineItem.Product2.Name}</td>
                        <td>{!lineItem.Quantity}</td>
                        <td>{!lineItem.UnitPrice}</td>
                        <td>{!lineItem.TotalPrice}</td>
                    </tr>
                </apex:repeat>
            </tbody>
        </table>
        <h2>Total Amount : {!opp.Amount}</h2>
    </body>
</apex:page>