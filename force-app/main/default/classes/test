import { LightningElement, wire, api } from 'lwc';
import { getRecord, getFieldValue } from 'lightning/uiRecordApi';

// Import the fields you want to autofill from the Opportunity
import ACCOUNT_NAME_FIELD from '@salesforce/schema/Opportunity.Account.Name';

export default class PicklistComponent extends LightningElement {
    @api recordId; // Automatically gets the Opportunity ID from the page

    companyName = '';
    contactName = '';
    contactEmail = '';
    contactPhone = '';

    @wire(getRecord, { 
        recordId: '$recordId', 
        fields: [ACCOUNT_NAME_FIELD] 
    })
    wiredOpportunity({ error, data }) {
        if (data) {
            // Autofill Company with the related Account Name
            this.companyName = getFieldValue(data, ACCOUNT_NAME_FIELD) || '';
            
            /* 
               If you store Contact Name, Email, or Phone directly on the Opportunity, 
               import those fields above and map them here like this:
               this.contactName = getFieldValue(data, OPPTY_CONTACT_NAME_FIELD) || '';
            */
        } else if (error) {
            console.error('Error fetching Opportunity data:', error);
        }
    }
}



<template>
    <form action="https://webto.salesforce.com/servlet/servlet.WebToCase?encoding=UTF-8&orgId=00Dg500000E9Rlh" method="POST">
        
        <!-- Hidden Required Fields -->
        <input type="hidden" name="orgid" value="00Dg500000E9Rlh" />
        <input type="hidden" name="retURL" value="http://" />
        <input type="hidden" id="external" name="external" value="1" />

        <!-- Autofilled Fields -->
        <label for="name">Contact Name</label>
        <input id="name" maxlength="80" name="name" size="20" type="text" value={contactName} /><br/>

        <label for="email">Email</label>
        <input id="email" maxlength="80" name="email" size="20" type="text" value={contactEmail} /><br/>

        <label for="phone">Phone</label>
        <input id="phone" maxlength="40" name="phone" size="20" type="text" value={contactPhone} /><br/>

        <label for="company">Company</label>
        <input id="company" maxlength="80" name="company" size="20" type="text" value={companyName} /><br/>

        <!-- Manual Entry Fields -->
        <label for="subject">Subject</label>
        <input id="subject" maxlength="80" name="subject" size="20" type="text" /><br/>

        <label for="description">Description</label>
        <textarea name="description"></textarea><br/>

        <label for="reason">Case Reason</label>
        <select id="reason" name="reason">
            <option value="">--None--</option>
            <option value="Installation">Installation</option>
            <option value="Equipment Complexity">Equipment Complexity</option>
            <option value="Performance">Performance</option>
            <option value="Breakdown">Breakdown</option>
            <option value="Equipment Design">Equipment Design</option>
            <option value="Feedback">Feedback</option>
            <option value="Other">Other</option>
        </select><br/>

        <input type="submit" name="submit" value="Submit Case" />
    </form>
</template>